# agentdata configuration — copy to .env and fill in only what you use.
# Everything has an offline-safe default; no keys are required for local sources,
# unify, emit, select, or the diagnosis rule table.

# --- teacher LLM for synthetic generation (generate/) ---
# auto -> AnthropicProvider iff ANTHROPIC_API_KEY is set, else deterministic MockProvider
LLM_PROVIDER=auto                     # auto | mock | anthropic
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=                    # only needed for provider=anthropic / auto with a key

# --- source selection ---
# single ("local") or a "+"/"," list ("local+huggingface") to fan out + dedupe
SOURCE=local

# --- paths ---
DATA_DIR=../dataset                   # local corpora root (sft_medical.jsonl, etc.)
OUT_DIR=out                           # where emitted datasets + manifests land
CACHE_DIR=.data/cache                 # downloaded raw source cache

# --- huggingface source (extra: agentdata[hf]) ---
HF_TOKEN=                             # for gated/private datasets
HF_CACHE_DIR=                         # overrides datasets default cache

# --- kaggle source (extra: agentdata[kaggle]) ---
# or place credentials in ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- physionet source (extra: agentdata[physionet]) — DUA-gated, non-redistributable ---
PHYSIONET_USER=
PHYSIONET_PASSWORD=

# --- github source (extra: agentdata[github]) ---
GITHUB_TOKEN=                         # for private repos / higher rate limits

# --- diagnosis ---
DIAGNOSE_THRESHOLD=0.6                # below this per-category score = a gap
